# Spotify OAuth — https://developer.spotify.com/dashboard
# Redirect URI (dev): http://localhost:3000/api/auth/callback/spotify
AUTH_SPOTIFY_ID=
AUTH_SPOTIFY_SECRET=

# NextAuth — openssl rand -base64 32
AUTH_SECRET=

# App URL (dev)
AUTH_URL=http://localhost:3000

# SQLite (dev) — use Turso/libsql URL in production
DATABASE_URL="file:./dev.db"
