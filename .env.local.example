# Spotify OAuth — https://developer.spotify.com/dashboard
# Redirect URI (dev): http://localhost:3000/api/auth/callback/spotify
AUTH_SPOTIFY_ID=
AUTH_SPOTIFY_SECRET=

# NextAuth — openssl rand -base64 32
AUTH_SECRET=

# App URL (local dev)
AUTH_URL=http://localhost:3000

# Production: set AUTH_URL to your canonical site URL (e.g. https://your-app.vercel.app)

# Database — use one URI from Supabase only; do not split credentials in app code.
#
# Supabase Dashboard → Project Settings → Database → Connection string → URI
# Choose the pooler / "Transaction" mode string for serverless (port 6543).
# Paste the full URI unchanged into Vercel (Project → Settings → Environment Variables).
#
# If you build the URI yourself, the password must be URL-encoded (e.g. ? → %3F, & → %26).
DATABASE_URL=

# Prisma migrations (CLI only): direct connection, port 5432 — same dashboard, "Direct" URI
DIRECT_URL=
