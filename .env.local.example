# Spotify OAuth — https://developer.spotify.com/dashboard
# Redirect URI (dev): http://localhost:3000/api/auth/callback/spotify
AUTH_SPOTIFY_ID=
AUTH_SPOTIFY_SECRET=

# NextAuth — openssl rand -base64 32
AUTH_SECRET=

# App URL (dev)
AUTH_URL=http://localhost:3000

# Supabase Postgres (pooler for serverless — port 6543)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection for migrations only (port 5432)
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"
